# ============================================================================
# SUPABASE
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Bucket de Storage para PDFs y adjuntos
NEXT_PUBLIC_SUPABASE_BUCKET_ATTACHMENTS=pdfs

# ============================================================================
# EMAIL (Resend)
# ============================================================================
# Obtén tu API key en: https://resend.com/api-keys
# Free tier: 3,000 emails/mes, 100 emails/día
RESEND_API_KEY=re_your_api_key
# Sin dominio verificado, usar: onboarding@resend.dev (solo para testing)
# Con dominio verificado: notificaciones@tudominio.com
FROM_EMAIL=onboarding@resend.dev
FROM_NAME=EDIFIKA

# ============================================================================
# SITE URL (necesario para generación de PDFs y emails)
# ============================================================================
# En desarrollo: http://localhost:3000
# En producción: https://app.edifika.com (o tu dominio)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================================
# SEGURIDAD (Opcional)
# ============================================================================
# Secret dedicado para firmar links públicos de estado de cuenta.
# Si no se configura, se usa SUPABASE_SERVICE_ROLE_KEY como fallback.
# LINK_SIGNING_SECRET=your-random-secret-here
